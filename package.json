{
  "name": "BondYieldCalculator",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:release": "cd android && ./gradlew assembleRelease && killall -9 java",
    "android:bundle": "cd android && ./gradlew bundleRelease && killall -9 java",
    "ios": "react-native run-ios",
    "ios:release": "react-native run-ios --mode=Release",
    "start": "react-native start",
    "start:clean": "react-native start --reset-cache",
    "node:clean": "rm -rf node_modules && npm cache clean --force && npm install",
    "android:clean": "npm run node:clean && cd android && ./gradlew clean",
    "ios:pod-reset": "cd ios && pod deintegrate && pod setup && pod install",
    "ios:clean": "npm run node:clean && cd ios && rm -rf ~/Library/Caches/CocoaPods && rm -rf Pods && rm -rf ~/Library/Developer/Xcode/DerivedData/* && npm run ios:pod-reset",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint --fix . --ext .js,.jsx,.ts,.tsx",
    "devtools": "react-devtools",
    "link-assets": "npx react-native-asset"
  },
  "dependencies": {
    "i18next": "^25.8.18",
    "react": "18.3.1",
    "react-i18next": "^16.5.8",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "^5.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.76.9",
    "@react-native/eslint-config": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "@react-native/typescript-config": "0.76.9",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
